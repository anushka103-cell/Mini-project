# ============================================================
# MindSafe — Free Tier Environment Variables
# ============================================================
# All services below have permanent free tiers (no credit card
# required except where noted).
#
# 1. Sign up at each provider, create the free resource
# 2. Copy connection strings into this file
# 3. Paste values into Render dashboard → Environment tab
# ============================================================

# ── Vercel (Frontend) ──
# Set these in Vercel dashboard → Settings → Environment Variables
NEXT_PUBLIC_API_URL=https://mindsafe-api.onrender.com
NEXT_PUBLIC_WS_URL=wss://mindsafe-api.onrender.com
NEXT_PUBLIC_GOOGLE_AUTH_URL=https://mindsafe-api.onrender.com/api/auth/google

# ── Neon PostgreSQL (free: 0.5 GB, auto-suspend) ──
# Sign up: https://neon.tech → Create project → Copy connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/mindsafe_db?sslmode=require

# ── Upstash Redis (free: 10K commands/day, 256 MB) ──
# Sign up: https://upstash.com → Create database → Copy REST URL
REDIS_URL=rediss://default:xxx@apn1-xxx.upstash.io:6379

# ── CloudAMQP RabbitMQ (free LazyFox: 1M messages/month) ──
# Sign up: https://www.cloudamqp.com → Create instance (LazyFox) → Copy AMQP URL
RABBITMQ_URL=amqps://user:pass@rattlesnake.rmq.cloudamqp.com/user

# ── API Gateway (Render) ──
NODE_ENV=production
PORT=5000
USE_POSTGRES=true
CORS_ORIGINS=https://mindsafe.vercel.app

# ── JWT / Encryption (Render auto-generates these via render.yaml) ──
# If setting manually, use 64+ character random strings:
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EMAIL_VERIFICATION_SECRET=
JWT_PASSWORD_RESET_SECRET=
DATA_ENCRYPTION_KEY=
DATA_HMAC_KEY=

# ── Internal service URLs (Render service names) ──
CHATBOT_SERVICE_URL=https://mindsafe-chatbot.onrender.com
EMOTION_DETECTION_URL=https://mindsafe-emotion.onrender.com
MOOD_ANALYTICS_URL=https://mindsafe-mood.onrender.com
CRISIS_DETECTION_URL=https://mindsafe-crisis.onrender.com

# ── Email (Resend free: 100 emails/day) ──
# Sign up: https://resend.com
RESEND_API_KEY=
EMAIL_FROM=MindSafe <onboarding@resend.dev>

# ── SMS / OTP (optional — Twilio trial: $15 credit) ──
# Sign up: https://twilio.com
SMS_PROVIDER=console
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ── Google OAuth (free) ──
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://mindsafe-api.onrender.com/api/auth/google/callback
