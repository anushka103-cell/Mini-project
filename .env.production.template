# ============================================================
# MindSafe — Environment Variables Reference
# ============================================================
# NEVER commit real secrets. Use AWS Secrets Manager in prod.
# Copy this file to .env.local for local dev.
# ============================================================

# ── Environment ──
NODE_ENV=production
PYTHON_ENV=production

# ── Frontend (build-time, NEXT_PUBLIC_ prefix required) ──
NEXT_PUBLIC_API_URL=https://mindsafe.example.com
NEXT_PUBLIC_WS_URL=wss://mindsafe.example.com
NEXT_PUBLIC_GOOGLE_AUTH_URL=https://mindsafe.example.com/api/auth/google

# ── API Gateway ──
PORT=5000
USE_POSTGRES=true
CORS_ORIGINS=https://mindsafe.example.com

# ── Database (managed RDS in prod) ──
DATABASE_URL=postgresql://mindsafe_admin:<PASSWORD>@<RDS_ENDPOINT>:5432/mindsafe_db

# ── Redis (managed ElastiCache in prod) ──
REDIS_URL=rediss://:<AUTH_TOKEN>@<ELASTICACHE_ENDPOINT>:6379/0

# ── RabbitMQ (managed Amazon MQ in prod) ──
RABBITMQ_URL=amqps://mindsafe_mq:<PASSWORD>@<MQ_ENDPOINT>

# ── JWT / Encryption (min 32 chars each in production) ──
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EMAIL_VERIFICATION_SECRET=
JWT_PASSWORD_RESET_SECRET=
DATA_ENCRYPTION_KEY=
DATA_HMAC_KEY=
JWT_ISSUER=mindsafe-api
JWT_AUDIENCE=mindsafe-clients
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
PASSWORD_RESET_TTL=1h
BCRYPT_ROUNDS=12

# ── Email (Resend — https://resend.com) ──
RESEND_API_KEY=
EMAIL_FROM=MindSafe <noreply@yourdomain.com>

# ── SMS / OTP (set SMS_PROVIDER to twilio or aws-sns) ──
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://mindsafe.example.com/api/auth/google/callback

# ── ML Microservices (internal DNS via CloudMap) ──
EMOTION_DETECTION_URL=http://emotion-detection.mindsafe-prod.local:8001
MOOD_ANALYTICS_URL=http://mood-analytics.mindsafe-prod.local:8002
CRISIS_DETECTION_URL=http://crisis-detection.mindsafe-prod.local:8003
CHATBOT_SERVICE_URL=http://chatbot.mindsafe-prod.local:8004

# ── ML Settings ──
USE_NLP_CRISIS_CLASSIFIER=true
USE_EXTERNAL_EMOTION_SERVICE=false
MODEL_DEVICE=cpu
LOG_LEVEL=WARNING
